# ==========================================
# PROJECT-SPECIFIC IGNORES
# ==========================================

# ===== AUDIO FILES (LARGE - DO NOT COMMIT) =====
# Ignore ALL .wav files in the youtube_audio directory
data/raw/youtube_audio/*.wav
data/raw/youtube_audio/**/*.wav

# ===== PROCESSED DATA CSVs (CAN BE REGENERATED) =====
# These are outputs from processing - don't commit them
data/raw/combined_match_download_results.csv
data/raw/youtube_matches.csv
data/raw/youtube_download_status.csv
data/interim/youtube_audio_features*.csv
data/processed/*.csv

# ===== KEEP IMPORTANT CSVs (OVERRIDE ABOVE) =====
# IMPORTANT: Keep the original Spotify dataset!
!data/raw/spotify_tracks.csv
!data/raw/spotify_cleaned.csv

# ===== MODEL FILES (LARGE) =====
models/*.joblib
models/*.pkl
models/*.h5
models/*.pt

