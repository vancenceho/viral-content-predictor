# ==========================================
# PROJECT-SPECIFIC
# ==========================================

# Data: raw/processed/cleaned/interim stay out of git (use Makefile / Hugging Face downloads).
# Keep only .gitkeep and .gitattributes under data/raw/ and data/cleaned/ (LFS pointers / metadata).
data/raw/**
data/cleaned/**
data/processed/**
data/interim/**
!data/raw/.gitkeep
!data/raw/.gitattributes
!data/cleaned/.gitkeep
!data/cleaned/.gitattributes
!data/processed/.gitkeep

# Trained weights & large artifacts (download from Hugging Face; do not commit)
models/*.joblib
models/*.pkl
models/*.h5
models/*.pt
models/*.pth
notebooks/models/**
!notebooks/models/.gitkeep

# Notebook outputs (regenerate from cells)
notebooks/images/**/*.png

# Secrets
secrets.sh

# Generic binary / doc types we do not want in-repo
*.dat
*.efx
*.gbr
*.key
*.pps
*.ppt
*.pptx
*.sdf
*.tax2010
*.vcf
*.xml

# Scratch / dev notebook patterns (any folder under notebooks/)
notebooks/**/scratch*.ipynb
notebooks/**/test_*.ipynb
notebooks/**/*test*.ipynb
notebooks/**/progree.ipynb
