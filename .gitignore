# ==========================================
# PROJECT-SPECIFIC IGNORES
# ==========================================

# ----- DATA: do not commit (large / reproducible; use scripts, Makefile, README) -----
# Ignore all dataset outputs. Keep only .gitkeep so empty dirs stay in the repo.
data/raw/**
data/processed/**
data/cleaned/**
data/interim/**
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/cleaned/.gitkeep

# Explicit extras (redundant with ** above; kept for clarity)
data/**/*.parquet

# ----- MODEL FILES (LARGE) -----
# Repo-root models/ (if used)
models/*.joblib
models/*.pkl
models/*.h5
models/*.pt
models/*.pth
# notebooks/models/ — placeholder only. Do not commit trained weights; download from Hugging Face for inference/ensemble.
notebooks/models/**
!notebooks/models/.gitkeep
# Generated plots (from notebooks; regenerate from training cells)
notebooks/images/**/*.png

# ----- SECRETS -----
secrets.sh
*.env
.env.local

